# Required: LLM provider
OPENAI_API_KEY=sk-...

# Optional model override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Web search — set at least one
# Prefer Tavily for LangChain/LangGraph agents
TAVILY_API_KEY=tvly-...

# Optional fallback if Tavily is not configured
# SERPAPI_API_KEY=...

# Search provider: tavily | serpapi (default: tavily)
SEARCH_PROVIDER=tavily

# Set to 1 to exercise the full SSE UI/API path without live API keys
# AGENT_MOCK=1
